# ─── BASE DE DATOS ────────────────────────────────────────────
DATABASE_URL=postgresql://mediqueue_user:mediqueue_pass@localhost:5432/mediqueue

# ─── JWT ──────────────────────────────────────────────────────
# Genera uno seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_de_al_menos_32_caracteres

